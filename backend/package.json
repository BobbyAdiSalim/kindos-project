{
  "name": "backend-example",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "start": "node --env-file=.env server.js",
    "dev": "nodemon --env-file=.env server.js",
    "db:init": "node --env-file=.env db-init.js",
    "db:reset": "node --env-file=.env db-init.js --force",
    "db:clean": "node scripts/db-clean-tables.cjs",
    "db:fresh": "npm run db:clean && npm run migrate",
    "db:fresh:seed": "npm run db:fresh && npm run seed",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "migrate:status": "sequelize-cli db:migrate:status",
    "migration:create": "sequelize-cli migration:generate --name",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo",
    "seed:undo:all": "sequelize-cli db:seed:undo:all",
    "seed:create": "sequelize-cli seed:generate --name",
    "seed:one": "sequelize-cli db:seed --seed"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "bcrypt": "^6.0.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.5",
    "dotenv": "^17.3.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
